# Copy to .env and fill in. Testnet only. Generate wallets with: uv run python scripts/gen_wallets.py

# Receiving wallets the API is paid into (one per chain). These are public addresses.
EVM_PAY_TO=0xYourBaseSepoliaReceiver
SVM_PAY_TO=YourSolanaDevnetReceiver

# Payer wallet secrets, used by the demo client (client/pay_and_fetch.py) only, never by the server.
EVM_PAYER_KEY=0xYourBaseSepoliaPayerPrivateKey
SVM_PAYER_KEY=YourSolanaDevnetPayerBase58SecretKey

# Facilitator that verifies and settles on-chain. The public default is keyless on both testnets.
FACILITATOR_URL=https://x402.org/facilitator

# Postgres. Empty disables the dataset and receipts (the 402 handshake still works on the bundled sample).
# Local docker: postgresql://postgres:x402@127.0.0.1:5433/x402 . Production: a Neon connection string.
DATABASE_URL=

# Prices in USD; the SDK converts to 6-decimal USDC atomic units.
PRICE_LOOKUP=$0.001
PRICE_SEARCH=$0.01
